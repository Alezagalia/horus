{
    "name": "@horus/mobile",
    "version": "0.0.1",
    "private": true,
    "description": "Horus Mobile App - React Native + Expo",
    "main": "index.js",
    "scripts": {
        "dev": "expo start",
        "start": "expo start",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "web": "expo start --web",
        "test": "jest",
        "test:e2e": "detox test",
        "test:e2e:ios": "detox test --configuration ios.sim.debug",
        "test:e2e:android": "detox test --configuration android.emu.debug",
        "build:e2e:ios": "detox build --configuration ios.sim.debug",
        "build:e2e:android": "detox build --configuration android.emu.debug",
        "type-check": "tsc --noEmit",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\""
    },
    "dependencies": {
        "@horus/shared": "workspace:*",
        "@gorhom/bottom-sheet": "^5.2.6",
        "@react-native-community/datetimepicker": "^8.4.4",
        "@react-navigation/bottom-tabs": "^7.13.0",
        "@react-navigation/material-top-tabs": "^7.4.3",
        "@react-navigation/native": "^7.1.20",
        "@react-navigation/native-stack": "^7.6.3",
        "@sentry/react-native": "^7.2.0",
        "@tanstack/react-query": "^5.90.10",
        "axios": "^1.13.2",
        "date-fns": "^4.1.0",
        "expo": "~53.0.0",
        "expo-auth-session": "^7.0.10",
        "expo-constants": "^18.0.13",
        "expo-device": "^8.0.10",
        "expo-linear-gradient": "^15.0.8",
        "expo-notifications": "^0.32.16",
        "expo-secure-store": "^15.0.8",
        "expo-status-bar": "^3.0.9",
        "expo-web-browser": "^15.0.10",
        "react": "18.3.1",
        "react-native": "0.76.5",
        "react-native-calendars": "^1.1313.0",
        "react-native-gesture-handler": "^2.28.0",
        "react-native-markdown-display": "^7.0.2",
        "react-native-pager-view": "^6.7.1",
        "react-native-reanimated": "~3.16.6",
        "react-native-safe-area-context": "^5.4.0",
        "react-native-screens": "^4.16.0",
        "react-native-svg": "^15.12.1",
        "victory-native": "^37.3.6",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "@types/react": "~18.3.12",
        "babel-preset-expo": "~13.0.0",
        "detox": "^20.46.0",
        "detox-expo-helpers": "^0.6.0",
        "jest": "^29.7.0",
        "jest-circus": "^30.2.0"
    }
}
