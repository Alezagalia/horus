# ===========================================
# Horus Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Database
# ===========================================
# PostgreSQL connection string
# For Railway: Use the DATABASE_URL provided by Railway PostgreSQL addon
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DATABASE_CONNECTION_LIMIT=10  # US-110: Connection pool limit

# ===========================================
# REQUIRED - Authentication
# ===========================================
# JWT secrets - generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# Token expiration (optional, defaults shown)
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# Server Configuration
# ===========================================
# Port (Railway sets this automatically via $PORT)
PORT=3000

# Environment
NODE_ENV="development"

# ===========================================
# Monitoring & Logging (US-115)
# ===========================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
LOG_LEVEL="info"

# ===========================================
# OPTIONAL - Google Calendar Sync (Sprint 8)
# ===========================================
# Required only for Google Calendar integration
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
ENCRYPTION_KEY=""  # 32 bytes hex for encrypting OAuth tokens

# ===========================================
# OPTIONAL - Push Notifications (Sprint 12)
# ===========================================
# Firebase Cloud Messaging (for mobile push)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Web Push VAPID Keys (for web push)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ===========================================
# Security Configuration
# ===========================================
# CORS: Comma-separated list of allowed origins (REQUIRED in production)
# Example: "https://horus.vercel.app,https://www.horus.app"
CORS_ORIGINS=""

# Rate Limiting (optional, defaults shown)
# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS="900000"
# Max requests per window for general endpoints (default: 100)
RATE_LIMIT_MAX_REQUESTS="100"
# Max attempts per window for auth endpoints (default: 5)
RATE_LIMIT_AUTH_MAX="5"

# ===========================================
# Password Reset / Transactional Email (Resend)
# ===========================================
# Optional in development: without RESEND_API_KEY the email service logs the
# reset link to the console instead of sending it.
# Get an API key at https://resend.com — free tier covers 100 emails/day.
RESEND_API_KEY="re_your_resend_api_key_here"

# "From" header for outgoing emails. Use the Resend sandbox sender to test
# without verifying a domain, or replace with your own verified address.
EMAIL_FROM="Horus <onboarding@resend.dev>"

# Base URL used to build the password-reset link in the email body.
# Local dev: http://localhost:5173 — production: your deployed frontend URL.
FRONTEND_URL="http://localhost:5173"

# Data retention (S-02.4).
# Expired/used auth tokens are always purged daily. Inactive accounts are only
# DELETED when BOTH of the following are set; otherwise the job runs dry-run
# (logs only) and never deletes. Keep disabled until a warning-email + grace
# period flow exists.
INACTIVE_ACCOUNT_PURGE_DAYS="0"          # 0 = disabled. e.g. 730 for 2 years.
INACTIVE_ACCOUNT_PURGE_ENABLED="false"   # "true" to actually delete.

# Plan gating (S-03). "false" = entitlement limits/Pro-features do NOT block
# anyone (no-op). Flip to "true" only once billing (Fase 2) is live.
BILLING_ENFORCED="false"

# Lemon Squeezy (Merchant of Record) — S-04. Fill from your LS dashboard. Use
# the TEST MODE keys/variants first. Leave empty to keep billing inactive (the
# checkout endpoint returns 503 until configured).
LEMONSQUEEZY_API_KEY=""              # Settings → API
LEMONSQUEEZY_STORE_ID=""             # your store id
LEMONSQUEEZY_WEBHOOK_SECRET=""       # Settings → Webhooks (signing secret)
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=""  # variant id of the monthly Pro plan
LEMONSQUEEZY_VARIANT_PRO_ANNUAL=""   # variant id of the annual Pro plan

# Google Play in-app subscriptions (mobile) — S-05. Leave empty to keep mobile
# billing inactive (the verify endpoint returns 503 until configured).
GOOGLE_PLAY_PACKAGE_NAME="com.horus.app"
# Full service-account credentials JSON on ONE line (Play Console → API access →
# a service account with the "Android Publisher" / financial-data permission).
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=""
# Subscription product ids created in Play Console (must match the mobile app's
# EXPO_PUBLIC_IAP_PRO_* and the SKUs the client requests).
GOOGLE_PLAY_PRODUCT_PRO_MONTHLY="pro_monthly"
GOOGLE_PLAY_PRODUCT_PRO_ANNUAL="pro_annual"
# Shared secret guarding the RTDN push endpoint (Pub/Sub → /api/billing/google/
# rtdn?secret=...). Generate a random string and set the same value in Pub/Sub.
GOOGLE_PLAY_RTDN_SECRET=""
